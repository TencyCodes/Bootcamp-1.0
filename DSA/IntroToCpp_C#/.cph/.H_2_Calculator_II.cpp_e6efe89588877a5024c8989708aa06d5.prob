{"name":"H2. Calculator - II","group":"Codeforces - Introduction to C++","url":"https://codeforces.com/group/4vcXCPx8NY/contest/664504/problem/H2","interactive":false,"memoryLimit":256,"timeLimit":1000,"tests":[{"id":1771484859354,"input":"1000000000\n1000000000\n","output":"1000000000 + 1000000000 = 2000000000\n\n1000000000 - 1000000000 = 0\n\n1000000000 * 1000000000 = 1000000000000000000\n\n1000000000 / 1000000000 = 1\n\n1000000000 % 1000000000 = 0\n"}],"testType":"single","input":{"type":"stdin"},"output":{"type":"stdout"},"languages":{"java":{"mainClass":"Main","taskClass":"H2CalculatorII"}},"batch":{"id":"c455f2d9-4c1a-4b88-b57c-7f42aa15e4ef","size":1},"srcPath":"c:\\kdrama\\New folder\\Bootcamp 1.0\\DSA\\IntroToCpp_C#\\H_2_Calculator_II.cpp"}